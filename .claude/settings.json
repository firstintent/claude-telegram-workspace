{
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "advisorModel": "opus",
  "permissions": {
    "allow": [
      "Bash",
      "Agent",
      "Glob",
      "Grep",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "mcp__plugin_telegram_telegram__reply",
      "mcp__plugin_telegram_telegram__react",
      "mcp__plugin_telegram_telegram__download_attachment",
      "WebSearch",
      "WebFetch",
      "Skill(update-config)",
      "Skill(telegram:access)",
      "Skill(claude-md-management:revise-claude-md)",
      "Skill(cct-telegram)",
      "Skill(cct-slash)",
      "Skill(cct-snapshot)",
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "Read(./.claude/channels/**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(curl * | *)",
      "Bash(wget * | *)"
    ]
  }
}
